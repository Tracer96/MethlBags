<Ui xmlns="http://www.blizzard.com/wow/ui/"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.blizzard.com/wow/ui/..\FrameXML\UI.xsd">

	<Script file="MethlBags.lua"/>

	<!-- Hidden tooltip used for item categorization (sorting) -->
	<GameTooltip name="MethlBagsTooltip" inherits="GameTooltipTemplate" hidden="true"/>

	<!-- Item button template -->
	<Button name="MethlBagsItemTemplate" hidden="true" virtual="true">
		<Size x="37" y="37"/>

		<Layers>
			<Layer level="BORDER">
				<Texture name="$parentIconTexture" setAllPoints="true"/>

				<FontString name="$parentCount" font="NumberFontNormal" justifyH="RIGHT" hidden="true">
					<Anchors>
						<Anchor point="BOTTOMRIGHT">
							<Offset x="-2" y="2"/>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>

			<Layer level="OVERLAY">
				<Texture name="$parentBorder" file="Interface\Buttons\UI-ActionButton-Border" alphaMode="ADD" hidden="true">
					<Size x="67" y="67"/>
					<Anchors>
						<Anchor point="CENTER"/>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>

		<Frames>
			<Model name="$parentCooldown" inherits="CooldownFrameTemplate"/>
		</Frames>

		<NormalTexture name="$parentNormalTexture" file="Interface\Buttons\UI-Quickslot2">
			<Size x="64" y="64"/>
			<Anchors>
				<Anchor point="CENTER">
					<Offset x="0" y="-1"/>
				</Anchor>
			</Anchors>
		</NormalTexture>
		<PushedTexture file="Interface\Buttons\UI-Quickslot-Depress"/>
		<HighlightTexture file="Interface\Buttons\ButtonHilight-Square" alphaMode="ADD"/>
	</Button>

	<!-- Main MethlBags frame -->
	<Button name="MethlBagsFrame" frameStrata="HIGH" movable="true" enableMouse="true" parent="UIParent" hidden="true">
		<Size x="410" y="400"/>

		<Anchors>
			<Anchor point="RIGHT">
				<Offset x="-4" y="-100"/>
			</Anchor>
		</Anchors>

		<Backdrop bgFile="Interface\ChatFrame\ChatFrameBackground" edgeFile="Interface\Tooltips\UI-Tooltip-Border">
			<BackgroundInsets>
				<AbsInset left="4" right="4" top="4" bottom="4"/>
			</BackgroundInsets>
			<TileSize>
				<AbsValue val="16"/>
			</TileSize>
			<EdgeSize>
				<AbsValue val="16"/>
			</EdgeSize>
		</Backdrop>

		<Frames>
			<!-- Close button -->
			<Button name="MethlBagsCloseButton" inherits="UIPanelCloseButton">
				<Anchors>
					<Anchor point="TOPRIGHT">
						<Offset x="-2" y="-2"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnClick>
						MethlBags_Hide();
					</OnClick>
				</Scripts>
			</Button>

			<!-- Title -->
			<Button name="MethlBagsFrameTitle">
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset x="10" y="-2"/>
					</Anchor>
					<Anchor point="BOTTOMRIGHT" relativeTo="MethlBagsCloseButton" relativePoint="BOTTOMLEFT">
						<Offset x="-2" y="4"/>
					</Anchor>
				</Anchors>

				<ButtonText setAllPoints="true"/>
				<NormalFont font="GameFontNormal" justifyH="LEFT"/>
				<HighlightFont font="GameFontHighlight" justifyH="LEFT"/>

				<Scripts>
					<OnMouseDown>
						MethlBags_StartMoving();
					</OnMouseDown>
					<OnMouseUp>
						MethlBags_StopMoving();
					</OnMouseUp>
				</Scripts>
			</Button>

			<!-- Item container (items are parented to this) -->
			<Frame name="MethlBagsFrameItems">
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset x="10" y="-28"/>
					</Anchor>
					<Anchor point="BOTTOMRIGHT">
						<Offset x="-10" y="42"/>
					</Anchor>
				</Anchors>
			</Frame>

			<!-- Bank toggle button -->
			<Button name="MethlBagsBankButton" inherits="UIPanelButtonTemplate" text="Show Bank">
				<Size x="85" y="21"/>
				<Anchors>
					<Anchor point="BOTTOMLEFT">
						<Offset x="8" y="8"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnClick>
						MethlBags_ToggleBank();
					</OnClick>
				</Scripts>
				<NormalFont font="GameFontNormalSmall"/>
				<DisabledFont font="GameFontDisableSmall"/>
				<HighlightFont font="GameFontHighlightSmall"/>
			</Button>

			<!-- Sort toggle button -->
			<Button name="MethlBagsSortButton" inherits="UIPanelButtonTemplate" text="Sorted">
				<Size x="70" y="21"/>
				<Anchors>
					<Anchor point="LEFT" relativeTo="MethlBagsBankButton" relativePoint="RIGHT">
						<Offset x="4" y="0"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnClick>
						MethlBags_ToggleSort();
					</OnClick>
				</Scripts>
				<NormalFont font="GameFontNormalSmall"/>
				<DisabledFont font="GameFontDisableSmall"/>
				<HighlightFont font="GameFontHighlightSmall"/>
			</Button>

			<!-- Money frame -->
			<Frame name="MethlBagsMoneyFrame" inherits="SmallMoneyFrameTemplate" hidden="false">
				<Anchors>
					<Anchor point="BOTTOMRIGHT">
						<Offset x="0" y="10"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnShow>
						MoneyFrame_UpdateMoney();
					</OnShow>
				</Scripts>
			</Frame>
		</Frames>

		<Scripts>
			<OnLoad>
				MethlBags_OnLoad();
				this:SetBackdropColor(0, 0, 0, 0.85);
				this:SetBackdropBorderColor(0.6, 0.6, 0.6, 1);
			</OnLoad>
			<OnEvent>
				MethlBags_OnEvent();
			</OnEvent>
			<OnMouseDown>
				MethlBags_StartMoving();
			</OnMouseDown>
			<OnMouseUp>
				MethlBags_StopMoving();
			</OnMouseUp>
			<OnHide>
				PlaySound("igBackPackClose");
			</OnHide>
		</Scripts>
	</Button>
</Ui>
